# g2-review-miner: Environment Variables
# =========================================
# Both variables are required. The skill will not run without them.

# Required: Google Gemini API key for review clustering and battlecard generation
# Get it: aistudio.google.com > Get API key
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Apify API token for scraping G2 and Capterra reviews
# Get it: console.apify.com/account/integrations
# Free tier includes $5 platform credits (~50 scraping runs)
APIFY_API_TOKEN=your_apify_api_token_here
